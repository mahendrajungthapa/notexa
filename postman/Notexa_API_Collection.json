{
  "info": {
    "_postman_id": "notexa-api-v2",
    "name": "Notexa API - Complete Collection",
    "description": "Full API collection for Notexa collaborative note-taking platform.\n\nBase URL: http://localhost:8000/api\n\nAuth: Bearer Token (get from /login or /register)\n\nSharing rules: share codes grant view-only access; edit access is only granted by the note owner to accepted friends.\n\nFiles: uploads can attach to owned/editable notes. If Cloudflare R2 is not configured, the API stores files locally and returns a temporary signed download URL.\n\nAdmin: admin@notexa.com / password123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" },
    { "key": "admin_token", "value": "" },
    { "key": "note_id", "value": "1" },
    { "key": "user_id", "value": "2" },
    { "key": "friendship_id", "value": "1" },
    { "key": "file_id", "value": "1" },
    { "key": "plan_id", "value": "1" },
    { "key": "payment_id", "value": "1" },
    { "key": "share_code", "value": "ABCD1234" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔓 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ram Sharma\",\n  \"username\": \"ramsharma\",\n  \"email\": \"ram@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Registration successful.\",\n  \"user\": {\n    \"id\": 2,\n    \"name\": \"Ram Sharma\",\n    \"username\": \"ramsharma\",\n    \"email\": \"ram@example.com\",\n    \"avatar\": null,\n    \"role\": \"user\",\n    \"is_premium\": false,\n    \"storage_used\": 0,\n    \"storage_limit\": 52428800,\n    \"is_active\": true,\n    \"created_at\": \"2026-04-03T10:00:00.000000Z\"\n  },\n  \"token\": \"1|abc123def456ghi789jkl012mno345pqr678stu901vwx\"\n}"
            },
            {
              "name": "Fail - Username taken",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"The username has already been taken.\",\n  \"errors\": {\n    \"username\": [\"The username has already been taken.\"]\n  }\n}"
            },
            {
              "name": "Fail - Validation",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"The password field must be at least 8 characters.\",\n  \"errors\": {\n    \"password\": [\"The password field must be at least 8 characters.\"],\n    \"email\": [\"The email has already been taken.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if(json.token) pm.collectionVariables.set('token', json.token);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"ramsharma\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"user\": {\n    \"id\": 2,\n    \"name\": \"Ram Sharma\",\n    \"username\": \"ramsharma\",\n    \"email\": \"ram@example.com\",\n    \"role\": \"user\",\n    \"is_premium\": false,\n    \"is_active\": true,\n    \"active_subscription\": null\n  },\n  \"token\": \"2|xyz789abc012def345ghi678jkl901mno234pqr567stu\"\n}"
            },
            {
              "name": "Fail - Wrong credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid credentials.\"\n}"
            },
            {
              "name": "Fail - Account deactivated",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Account deactivated.\"\n}"
            }
          ]
        },
        {
          "name": "Login as Admin",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if(json.token) pm.collectionVariables.set('admin_token', json.token);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"admin@notexa.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin\",\n    \"username\": \"admin\",\n    \"email\": \"admin@notexa.com\",\n    \"role\": \"admin\",\n    \"is_premium\": false\n  },\n  \"token\": \"3|admin_token_here\"\n}"
            }
          ]
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"user\": {\n    \"id\": 2,\n    \"name\": \"Ram Sharma\",\n    \"username\": \"ramsharma\",\n    \"email\": \"ram@example.com\",\n    \"is_premium\": false,\n    \"storage_used\": 1048576,\n    \"storage_limit\": 52428800\n  },\n  \"stats\": {\n    \"notes_count\": 5,\n    \"friends_count\": 3,\n    \"shared_with_me\": 2,\n    \"files_count\": 1,\n    \"storage_used_mb\": 1.0,\n    \"storage_limit_mb\": 50.0\n  }\n}"
            },
            {
              "name": "Fail - Unauthenticated",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ram K. Sharma\",\n  \"username\": \"ramksharma\"\n}" },
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] }
          },
          "response": [
            { "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"user\": { \"id\": 2, \"name\": \"Ram K. Sharma\", \"username\": \"ramksharma\" }\n}" }
          ]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"password123\",\n  \"password\": \"newpassword456\",\n  \"password_confirmation\": \"newpassword456\"\n}" },
            "url": { "raw": "{{base_url}}/change-password", "host": ["{{base_url}}"], "path": ["change-password"] }
          },
          "response": [
            { "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"message\": \"Password changed.\"\n}" },
            { "name": "Fail", "code": 400, "body": "{\n  \"status\": \"error\",\n  \"message\": \"Current password incorrect.\"\n}" }
          ]
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"message\": \"Logged out.\"\n}" }]
        }
      ]
    },
    {
      "name": "📝 Notes",
      "item": [
        {
          "name": "List Notes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/notes?search=&page=1&per_page=20", "host": ["{{base_url}}"], "path": ["notes"], "query": [{ "key": "search", "value": "" }, { "key": "page", "value": "1" }, { "key": "per_page", "value": "20" }] }
          },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"data\": [\n      {\n        \"id\": 1,\n        \"user_id\": 2,\n        \"title\": \"My First Note\",\n        \"content\": \"<p>Hello world</p>\",\n        \"plain_text\": \"Hello world\",\n        \"color\": \"#ffffff\",\n        \"is_pinned\": false,\n        \"is_archived\": false,\n        \"is_trashed\": false,\n        \"share_code\": \"XK7M2NPA\",\n        \"ai_summary\": null,\n        \"created_at\": \"2026-04-03T10:00:00.000000Z\",\n        \"updated_at\": \"2026-04-03T10:00:00.000000Z\"\n      }\n    ],\n    \"current_page\": 1,\n    \"last_page\": 1,\n    \"total\": 1\n  }\n}" }]
        },
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Sprint Planning Q4\",\n  \"content\": \"<h1>Sprint Planning</h1><p>Key priorities for Q4...</p>\",\n  \"color\": \"#dbeafe\"\n}" },
            "url": { "raw": "{{base_url}}/notes", "host": ["{{base_url}}"], "path": ["notes"] }
          },
          "response": [
            { "name": "Success", "code": 201, "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Sprint Planning Q4\",\n    \"content\": \"<h1>Sprint Planning</h1><p>Key priorities for Q4...</p>\",\n    \"color\": \"#dbeafe\",\n    \"share_code\": \"XK7M2NPA\",\n    \"ai_summary\": null\n  }\n}" },
            { "name": "Fail - Validation", "code": 422, "body": "{\n  \"message\": \"The title field is required.\",\n  \"errors\": { \"title\": [\"The title field is required.\"] }\n}" }
          ]
        },
        {
          "name": "Get Single Note",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/notes/{{note_id}}", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}"] } },
          "response": [
            { "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Sprint Planning Q4\",\n    \"content\": \"<h1>Sprint Planning</h1><p>Key priorities...</p>\",\n    \"share_code\": \"XK7M2NPA\",\n    \"ai_summary\": \"Focus on mobile launch and onboarding improvements for Q4.\",\n    \"user\": { \"id\": 2, \"name\": \"Ram\", \"username\": \"ramsharma\" },\n    \"shares\": [],\n    \"files\": []\n  },\n  \"permission\": \"owner\"\n}" },
            { "name": "Fail - Unauthorized", "code": 403, "body": "{\n  \"status\": \"error\",\n  \"message\": \"Unauthorized\"\n}" }
          ]
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Title\",\n  \"content\": \"<p>Updated content here</p>\",\n  \"color\": \"#fef3c7\"\n}" },
            "url": { "raw": "{{base_url}}/notes/{{note_id}}", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}"] }
          },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": { \"id\": 1, \"title\": \"Updated Title\" }\n}" }]
        },
        {
          "name": "Delete Note (Trash)",
          "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/notes/{{note_id}}", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"message\": \"Moved to trash.\"\n}" }]
        },
        {
          "name": "Restore Note",
          "request": { "method": "POST", "url": { "raw": "{{base_url}}/notes/{{note_id}}/restore", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "restore"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{ \"status\": \"success\" }" }]
        },
        {
          "name": "Permanent Delete",
          "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/notes/{{note_id}}/permanent", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "permanent"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{ \"status\": \"success\" }" }]
        },
        {
          "name": "Toggle Pin",
          "request": { "method": "PATCH", "url": { "raw": "{{base_url}}/notes/{{note_id}}/pin", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "pin"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": { \"id\": 1, \"is_pinned\": true }\n}" }]
        },
        {
          "name": "Toggle Archive",
          "request": { "method": "PATCH", "url": { "raw": "{{base_url}}/notes/{{note_id}}/archive", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "archive"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": { \"id\": 1, \"is_archived\": true }\n}" }]
        },
        {
          "name": "Get Share Code",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/notes/{{note_id}}/share-code", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "share-code"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"share_code\": \"XK7M2NPA\"\n}" }]
        },
        {
          "name": "Regenerate Share Code",
          "request": { "method": "POST", "url": { "raw": "{{base_url}}/notes/{{note_id}}/regenerate-code", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "regenerate-code"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"share_code\": \"P9QR4TUV\"\n}" }]
        },
        {
          "name": "Redeem Share Code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"XK7M2NPA\"\n}" },
            "url": { "raw": "{{base_url}}/notes/redeem-code", "host": ["{{base_url}}"], "path": ["notes", "redeem-code"] }
          },
          "response": [
            { "name": "Success - View Only", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"message\": \"Note 'Sprint Planning Q4' added to your shared notes.\",\n  \"data\": { \"id\": 1, \"title\": \"Sprint Planning Q4\", \"user\": { \"id\": 2, \"username\": \"ramsharma\" } }\n}" },
            { "name": "Fail - Invalid code", "code": 404, "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid code.\"\n}" },
            { "name": "Fail - Own note", "code": 400, "body": "{\n  \"status\": \"error\",\n  \"message\": \"This is your own note.\"\n}" },
            { "name": "Fail - Already shared", "code": 400, "body": "{\n  \"status\": \"error\",\n  \"message\": \"Already shared with you.\"\n}" }
          ]
        },
        {
          "name": "AI Summary",
          "request": { "method": "POST", "url": { "raw": "{{base_url}}/notes/{{note_id}}/ai-summary", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "ai-summary"] } },
          "response": [
            { "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"summary\": \"This note outlines Q4 sprint priorities: mobile app launch and onboarding flow improvements. Two key initiatives driving growth.\"\n}" },
            { "name": "Fail - No API key", "code": 500, "body": "{\n  \"status\": \"error\",\n  \"message\": \"AI service unavailable. Check DeepSeek API key in admin settings.\"\n}" },
            { "name": "Fail - Too short", "code": 400, "body": "{\n  \"status\": \"error\",\n  \"message\": \"Note is too short to summarize.\"\n}" }
          ]
        },
        {
          "name": "Archived Notes",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/notes/archived", "host": ["{{base_url}}"], "path": ["notes", "archived"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{ \"status\": \"success\", \"data\": { \"data\": [], \"total\": 0 } }" }]
        },
        {
          "name": "Trashed Notes",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/notes/trashed", "host": ["{{base_url}}"], "path": ["notes", "trashed"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{ \"status\": \"success\", \"data\": { \"data\": [], \"total\": 0 } }" }]
        },
        {
          "name": "Note Versions",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/notes/{{note_id}}/versions", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "versions"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"data\": [\n      { \"id\": 1, \"version_number\": 1, \"user\": { \"id\": 2, \"name\": \"Ram\" }, \"created_at\": \"2026-04-03T10:00:00Z\" }\n    ]\n  }\n}" }]
        }
      ]
    },
    {
      "name": "🤝 Sharing",
      "item": [
        {
          "name": "Share Note with Friend",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"user_id\": 3,\n  \"permission\": \"edit\"\n}" },
            "url": { "raw": "{{base_url}}/notes/{{note_id}}/share", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "share"] }
          },
          "response": [
            { "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"message\": \"Shared with @sita.\",\n  \"data\": { \"id\": 1, \"permission\": \"edit\", \"recipient\": { \"id\": 3, \"name\": \"Sita\", \"username\": \"sita\" } }\n}" },
            { "name": "Fail - Not owner", "code": 403, "body": "{ \"status\": \"error\", \"message\": \"Only owner can share.\" }" },
            { "name": "Fail - Not friends", "code": 403, "body": "{ \"status\": \"error\", \"message\": \"Add this user as a friend before sharing notes.\" }" }
          ]
        },
        {
          "name": "Update Permission",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"permission\": \"view\" }" },
            "url": { "raw": "{{base_url}}/notes/{{note_id}}/share/{{user_id}}", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "share", "{{user_id}}"] }
          },
          "response": [{ "name": "Success", "code": 200, "body": "{ \"status\": \"success\", \"data\": { \"permission\": \"view\" } }" }]
        },
        {
          "name": "Unshare",
          "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/notes/{{note_id}}/share/{{user_id}}", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "share", "{{user_id}}"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{ \"status\": \"success\" }" }]
        },
        {
          "name": "List Collaborators",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/notes/{{note_id}}/collaborators", "host": ["{{base_url}}"], "path": ["notes", "{{note_id}}", "collaborators"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": [\n    { \"id\": 1, \"shared_with\": 3, \"permission\": \"edit\", \"recipient\": { \"id\": 3, \"name\": \"Sita\", \"username\": \"sita\" } }\n  ]\n}" }]
        },
        {
          "name": "Shared with Me",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/shared-with-me", "host": ["{{base_url}}"], "path": ["shared-with-me"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"data\": [\n      { \"id\": 1, \"title\": \"Sprint Planning\", \"user\": { \"id\": 2, \"username\": \"ramsharma\" }, \"pivot\": { \"permission\": \"edit\" } }\n    ]\n  }\n}" }]
        }
      ]
    },
    {
      "name": "👥 Friends",
      "item": [
        {
          "name": "My Friends",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/friends", "host": ["{{base_url}}"], "path": ["friends"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": [\n    { \"id\": 3, \"name\": \"Sita Devi\", \"username\": \"sita\", \"email\": \"sita@example.com\", \"is_premium\": true }\n  ]\n}" }]
        },
        {
          "name": "Pending Requests",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/friends/requests", "host": ["{{base_url}}"], "path": ["friends", "requests"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"received\": [{ \"id\": 1, \"sender\": { \"id\": 4, \"name\": \"Hari\", \"username\": \"hari\" }, \"status\": \"pending\" }],\n    \"sent\": [{ \"id\": 2, \"receiver\": { \"id\": 5, \"name\": \"Gita\", \"username\": \"gita\" }, \"status\": \"pending\" }]\n  }\n}" }]
        },
        {
          "name": "Send Friend Request (by username)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"sita\"\n}" },
            "url": { "raw": "{{base_url}}/friends/request", "host": ["{{base_url}}"], "path": ["friends", "request"] }
          },
          "response": [
            { "name": "Success", "code": 200, "body": "{\n  \"status\": \"success\",\n  \"message\": \"Friend request sent to @sita.\"\n}" },
            { "name": "Fail - Not found", "code": 404, "body": "{ \"status\": \"error\", \"message\": \"User not found.\" }" },
            { "name": "Fail - Already friends", "code": 400, "body": "{ \"status\": \"error\", \"message\": \"Already friends.\" }" },
            { "name": "Fail - Self", "code": 400, "body": "{ \"status\": \"error\", \"message\": \"Cannot add yourself.\" }" }
          ]
        },
        {
          "name": "Accept Request",
          "request": { "method": "PUT", "url": { "raw": "{{base_url}}/friends/accept/{{friendship_id}}", "host": ["{{base_url}}"], "path": ["friends", "accept", "{{friendship_id}}"] } },
          "response": [{ "name": "Success", "code": 200, "body": "{ \"status\": \"success\", \"message\": \"Friend request accepted.\" }" }]
        },
